{
	"name": "@rifted/content-monorepo",
	"private": true,
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rifted-game/content.git"
	},
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "bun run --filter '*' build",
		"pack": "bun run --filter '*' pack",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "bun run --filter '*' typecheck",
		"changeset": "changeset",
		"version-packages": "changeset version && rm -f bun.lock && bun install",
		"release": "bun run build && bun run scripts/publish.ts",
		"prepare": "lefthook install"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@changesets/cli": "^2.31.0",
		"@rifted/cli": "^1.1.0",
		"@types/bun": "^1.3.14",
		"lefthook": "^1.10.0",
		"lint-staged": "^15.2.0",
		"typescript": "^5.7.0"
	},
	"engines": {
		"node": ">=20"
	}
}
